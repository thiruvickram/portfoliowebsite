.education .education-content .education-item {
    display: flex;
    flex-direction: column;
    align-items: center;  /* centers all subject rows */
    gap: 10px;            /* spacing between rows */
}

.education .education-content .education-item .subject {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 20px;
    display: flex;
    width: 400px; 
}
.education .education-content .education-item .subject i {
    font-size: 30px;
    color: var(--secondary-color);
}

.education .education-content .education-item .subject .subject-name {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    background-color: var(--secondary-color);
    color: var(--primary-color);
    font-size: 20px;
    gap: 20px;
    margin-bottom: 10px;
    flex: 1;                /* makes it expand */
    background: var(--tertiary-color);
    display: flex;          /* centers text */
    height: 60px;           /* set the height */
    border-radius: 10px;    /* rounded corners */}

 .education .education-content .education-item .subject .subject-grade {
    width: 80px;            /* smaller fixed width */
    background-color: var(--primary-color);
    color: var(--secondary-color);
    font-size: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dotted var(--secondary-color);
    margin-bottom: 10px;
    height: 60px;  
    border-radius: 10px;         /* SAME height as word-box */
}